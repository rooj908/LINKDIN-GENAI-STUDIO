# Copy this file to .env and fill in your key to enable LIVE AI MODE.
# Without this, the app runs perfectly fine in DEMO MODE (no key needed).

OPENAI_API_KEY=your_openai_or_grok_api_key_here

# Optional: override if using Grok or another OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.x.ai/v1
# OPENAI_MODEL=grok-2-latest
